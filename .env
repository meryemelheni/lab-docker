# Variables de configuration pour docker-compose et l'app
# Si vous utilisez PostgreSQL installé sur la machine hôte, ajustez DB_HOST
# (par exemple "host.docker.internal" sous Windows/Mac, "localhost" avec réseau
# host ou utilisation directe hors de compose). Ne commitez jamais de mots de passe en dur.

# base de données
DB_NAME=taskflow
DB_USER=taskuser
DB_PASSWORD=taskpass
DB_PORT=5432
# si PostgreSQL est déjà présent sur votre PC, définissez l'hôte suivant :
DB_HOST=host.docker.internal

# ports des services exposés
BACKEND_PORT=3000
FRONTEND_PORT=8080
